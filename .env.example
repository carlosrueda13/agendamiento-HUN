# Meta webhook verification token. Use the same value in Meta Developers.
VERIFY_TOKEN=token_de_verificacion_para_meta

# WhatsApp Cloud API credentials.
WHATSAPP_TOKEN=token_de_meta
PHONE_NUMBER_ID=id_del_numero_de_whatsapp_cloud_api
GRAPH_API_VERSION=v23.0

# Optional local server port. Do not set this in Render; Render injects PORT automatically.
# PORT=3000

# WhatsApp Flow identifiers.
FLOW_ID=id_del_flow_creado_en_whatsapp_manager
FLOW_SCREEN_ID=IDENTIFICACION

# Separate WhatsApp Flow used to modify an existing appointment.
RESCHEDULE_FLOW_ID=1055273933723521
RESCHEDULE_FLOW_SCREEN_ID=IDENTIFICACION_REAGENDAMIENTO

# Separate WhatsApp Flow used by demand-induction campaigns.
# This Flow is launched from a WhatsApp template and must not reuse FLOW_ID.
CAMPAIGN_FLOW_ID=2195324014654953
CAMPAIGN_FLOW_SCREEN_ID=IDENTIFICACION
CAMPAIGN_TEMPLATE_NAME=hun_oferta_cita_flow
CAMPAIGN_TEMPLATE_LANGUAGE=es_CO

# Optional separate backend key for signed demand-induction flow_token values.
# If omitted, the backend derives this key from FLOW_SLOT_TOKEN_SECRET_B64 or FLOW_SESSION_PII_KEY_B64.
CAMPAIGN_FLOW_TOKEN_SECRET_B64=clave_32_bytes_base64_para_campaign_flow_tokens

# Private key used by WhatsApp Flows data_exchange encryption.
# Store the PEM content encoded in base64, without line breaks.
FLOW_PRIVATE_KEY_B64=llave_privada_pem_en_base64
FLOW_KEY_PASSPHRASE=

# Backend encryption key for transient Flow session contact data.
# Required in SETUP-005 to encrypt contacto_email_enc and derive contacto_email_hmac.
# Generate 32 random bytes and encode them in base64.
FLOW_SESSION_PII_KEY_B64=clave_32_bytes_base64_para_contacto_transitorio

# Optional separate backend key for signed slot_token values.
# If omitted, the backend derives the slot HMAC key from FLOW_SESSION_PII_KEY_B64.
FLOW_SLOT_TOKEN_SECRET_B64=clave_32_bytes_base64_para_slot_tokens

# Temporary FLOW-003 waiver only. Leave empty/false outside the controlled E2E test.
# Allows non-autogestionable HUN slots only for listed test documents and cancels
# the appointment after assignment.
FLOW_E2E_ALLOW_NON_AUTOGESTIONABLE=false
FLOW_E2E_CANCEL_AFTER_ASSIGN=false
FLOW_E2E_TEST_DOCUMENTS=

# HUN API.
HUN_API_BASE=http://190.109.10.204
HUN_API_KEY=HospitalUniversitarioNacionaldeColombia

# Asynchronous HUN cancellation verification. Optional; defaults shown.
CANCEL_VERIFY_MAX_ATTEMPTS=6
CANCEL_VERIFY_INTERVAL_MS=2000
CANCEL_VERIFY_INITIAL_DELAY_MS=1500

# HUN demand-induction audience API.
# Configure these when the hospital provides the official endpoint.
HUN_DEMANDA_API_BASE=
HUN_DEMANDA_API_AUTH_TYPE=
HUN_DEMANDA_API_TOKEN=
HUN_DEMANDA_API_ENDPOINT=
HUN_DEMANDA_API_TIMEOUT_MS=20000
# Optional request filters/pagination are passed by the backend when syncing a campaign.
# Supported auth types in the backend adapter: none, bearer, api_key, x-api-key.

# HUN orchestrator resolver used by campaigns to resolve a pseudonymous
# audience reference into transient contact/context before sending WhatsApp.
# Do not persist the returned phone, name, email, EPS, doctor, appointment
# date/time, service, or full payload in Supabase.
HUN_ORQUESTADOR_API_BASE=
HUN_ORQUESTADOR_API_KEY=
HUN_ORQUESTADOR_API_ENDPOINT=/api/v1/get-appointment/{id_anonimo}

# EmailJS confirmation emails. Optional until the provider is approved/configured.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Supabase minimal operational storage. Do not store appointments or sensitive patient data.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key
