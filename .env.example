# Meta webhook verification token. Use the same value in Meta Developers.
VERIFY_TOKEN=token_de_verificacion_para_meta

# WhatsApp Cloud API credentials.
WHATSAPP_TOKEN=token_de_meta
PHONE_NUMBER_ID=id_del_numero_de_whatsapp_cloud_api
GRAPH_API_VERSION=v23.0

# Optional local server port. Do not set this in Render; Render injects PORT automatically.
# PORT=3000

# WhatsApp Flow identifiers.
FLOW_ID=id_del_flow_creado_en_whatsapp_manager
FLOW_SCREEN_ID=IDENTIFICACION

# Private key used by WhatsApp Flows data_exchange encryption.
# Store the PEM content encoded in base64, without line breaks.
FLOW_PRIVATE_KEY_B64=llave_privada_pem_en_base64
FLOW_KEY_PASSPHRASE=

# Backend encryption key for transient Flow session contact data.
# Required in SETUP-005 to encrypt contacto_email_enc and derive contacto_email_hmac.
# Generate 32 random bytes and encode them in base64.
FLOW_SESSION_PII_KEY_B64=clave_32_bytes_base64_para_contacto_transitorio

# Optional separate backend key for signed slot_token values.
# If omitted, the backend derives the slot HMAC key from FLOW_SESSION_PII_KEY_B64.
FLOW_SLOT_TOKEN_SECRET_B64=clave_32_bytes_base64_para_slot_tokens

# HUN API.
HUN_API_BASE=http://190.109.10.204
HUN_API_KEY=HospitalUniversitarioNacionaldeColombia

# HUN demand-induction audience API.
# Configure these when the hospital provides the official endpoint.
HUN_DEMANDA_API_BASE=
HUN_DEMANDA_API_AUTH_TYPE=
HUN_DEMANDA_API_TOKEN=
HUN_DEMANDA_API_ENDPOINT=
HUN_DEMANDA_API_TIMEOUT_MS=20000

# EmailJS confirmation emails. Optional until the provider is approved/configured.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=

# Supabase minimal operational storage. Do not store appointments or sensitive patient data.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key
